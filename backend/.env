# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database-name?retryWrites=true&w=majority
# Replace with your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://teachnexus_user:Password123@cluster0.zexsacf.mongodb.net/teachnexus?retryWrites=true&w=majority

# JWT secret key (change to something secure in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server port
PORT=5000

# Cloudinary for file storage (optional)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=teachnexus

# Email settings (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=TeachNexus <noreply@teachnexus.com>

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# WebSocket URL (for frontend connection)
WS_URL=http://localhost:5000

# OpenAI Integration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
