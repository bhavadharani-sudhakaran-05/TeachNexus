# TeachNexus Frontend Environment Variables
# Copy this file to .env and configure for your environment

# API Configuration
VITE_API_BASE=http://localhost:5000/api

# WebSocket Configuration (for chat and real-time features)
VITE_WS_URL=http://localhost:5000

# Yjs WebSocket URL (for collaborative editing)
VITE_YJS_URL=ws://localhost:5000/yjs

# Application Settings
VITE_APP_NAME=TeachNexus
VITE_APP_TAGLINE=Empowering Educators Together

# Feature Flags (optional)
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_CHAT=true
VITE_ENABLE_GAMIFICATION=true

# Analytics (optional)
# VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X

# Environment
VITE_NODE_ENV=development
